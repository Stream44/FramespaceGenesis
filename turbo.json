{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "dev": {
            "cache": false,
            "persistent": true
        },
        "build": {
            "env": [
                "CACHE_BUST_PATH_PREFIX"
            ],
            "outputs": [
                "dist/**",
                ".output/**",
                ".vinxi/**"
            ]
        },
        "start": {
            "dependsOn": [
                "build"
            ],
            "persistent": true
        }
    }
}